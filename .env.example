APP_ENV=docker
APP_HOST=0.0.0.0
APP_PORT=8000
TZ=Asia/Shanghai

POSTGRES_DB=smart_home
POSTGRES_USER=smart_home
POSTGRES_PASSWORD=smart_home
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://smart_home:smart_home@postgres:5432/smart_home

REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CONNECTION_ENCRYPTION_SECRET=change-this-in-real-env
HOME_ASSISTANT_PORT=8123
HOME_ASSISTANT_BOOTSTRAP_ENABLED=true
HOME_ASSISTANT_BOOTSTRAP_URL=http://homeassistant:8123
HOME_ASSISTANT_BOOTSTRAP_ACCESS_TOKEN=
HOME_ASSISTANT_BOOTSTRAP_CONNECTION_MODE=TOKEN
CAPABILITY_ENERGY_ENABLED=true
CAPABILITY_EDITOR_ENABLED=true
