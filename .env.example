APP_ENV=docker
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_PORT=5173
TZ=Asia/Shanghai

POSTGRES_DB=smart_home
POSTGRES_USER=smart_home
POSTGRES_PASSWORD=smart_home
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://smart_home:smart_home@postgres:5432/smart_home

REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_PER_MINUTE=600
RATE_LIMIT_AUTH_PER_MINUTE=60
RATE_LIMIT_PIN_PER_MINUTE=30
RATE_LIMIT_BOOTSTRAP_PER_MINUTE=60
RATE_LIMIT_PAIRING_PER_MINUTE=60
RATE_LIMIT_UPLOAD_PER_MINUTE=30
RATE_LIMIT_FILE_DOWNLOAD_PER_MINUTE=300
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REDIS_TIMEOUT_SECONDS=0.25

FRONTEND_MEM_LIMIT=128m
FRONTEND_CPUS=0.50
BACKEND_MEM_LIMIT=512m
BACKEND_CPUS=1.00
HOME_ASSISTANT_MEM_LIMIT=1024m
HOME_ASSISTANT_CPUS=1.00
SGCC_MEM_LIMIT=512m
SGCC_CPUS=1.00
POSTGRES_MEM_LIMIT=512m
POSTGRES_CPUS=1.00
REDIS_MEM_LIMIT=128m
REDIS_CPUS=0.50

# Required for APP_ENV=docker/production. Replace these placeholders before starting Compose.
# Generate separate random values for each secret; do not reuse the examples below.
CONNECTION_ENCRYPTION_SECRET=change-this-to-a-strong-random-secret-at-least-32-chars
ACCESS_TOKEN_SECRET=change-this-to-a-strong-random-secret-at-least-32-chars
BOOTSTRAP_TOKEN_SECRET=change-this-to-a-strong-random-secret-at-least-32-chars
HOME_ASSISTANT_PORT=8123
HOME_ASSISTANT_BOOTSTRAP_ENABLED=true
HOME_ASSISTANT_BOOTSTRAP_URL=http://homeassistant:8123
HOME_ASSISTANT_BOOTSTRAP_ACCESS_TOKEN=
HOME_ASSISTANT_BOOTSTRAP_CONNECTION_MODE=TOKEN
CAPABILITY_ENERGY_ENABLED=true
CAPABILITY_EDITOR_ENABLED=true
WEATHER_LOCATION_LABEL=赤峰红山区
WEATHER_HOME_ASSISTANT_ENTITY_ID=weather.forecast_wo_de_jia
WEATHER_LATITUDE=42.26298161148389
WEATHER_LONGITUDE=118.94726859100243
ENERGY_AUTO_REFRESH_ENABLED=true
ENERGY_AUTO_REFRESH_HOUR=7
ENERGY_AUTO_REFRESH_MINUTE=30
ENERGY_AUTO_REFRESH_TIMEZONE=Asia/Shanghai
ENERGY_UPSTREAM_REFRESH_MODE=sgcc_sidecar
ENERGY_UPSTREAM_WAIT_TIMEOUT_SECONDS=45
ENERGY_UPSTREAM_POLL_INTERVAL_SECONDS=5
SGCC_SIDECAR_BASE_URL=http://sgcc_electricity:8080
SGCC_SIDECAR_TIMEOUT_SECONDS=10
SGCC_SIDECAR_FALLBACK_ENABLED=false
DEV_BYPASS_TERMINAL_ACTIVATION=false
VITE_DEV_BYPASS_TERMINAL_ACTIVATION=false
VITE_BACKEND_PROXY_TARGET=http://localhost:8000
